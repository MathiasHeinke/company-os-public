# Company.OS Environment Example

# Copy values into your local secret manager or runtime-specific `.env` file.
# Do not commit real credentials.

COMPANY_OS_VERSION=0.6.5-beta.5
COMPANY_OS_AUTONOMY_CEILING=L2
COMPANY_OS_EXECUTION_LEDGER=plane
COMPANY_OS_TIMEZONE=Europe/Berlin

# Local workspace roots. Keep paths portable in committed files.
DEVELOPER_ROOT=${HOME}/Developer
COMPANY_OS_ROOT=${DEVELOPER_ROOT}/Company.OS
CLIENT_WORKSPACE_ROOT=${DEVELOPER_ROOT}/client-workspace
SANDBOX_ROOT=${DEVELOPER_ROOT}/_sandboxes

# Plane is required for Company.OS execution. Prefer Plane App / bot identity.
PLANE_WORKSPACE_SLUG=<plane-workspace-slug>
PLANE_DEFAULT_PROJECT_ID=<plane-project-uuid>
PLANE_AUTH_MODE=app-token

# Optional memory layer. Configure only after workspace boundaries are decided.
HONCHO_COMPANY_WORKSPACE_ID=<company-memory-workspace>
HONCHO_PERSONAL_WORKSPACE_ID=<personal-memory-workspace>
HONCHO_PRODUCT_WORKSPACE_ID=<product-memory-workspace>

# Optional connector roots. Leave unset until the first pilot wedge needs them.
AIONUI_SIDECAR_ROOT=
HERMES_SIDECAR_ROOT=
SUPABASE_PROJECT_REF=
UPLOAD_POST_BASE_URL=
STRIPE_ACCOUNT_ID=
