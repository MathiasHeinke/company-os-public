{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://company-os.local/schemas/eve/runtime-policy.schema.json",
  "title": "Command EVE Runtime Policy",
  "type": "object",
  "required": [
    "version",
    "updated_at",
    "profile",
    "release_band",
    "default_mode",
    "north_star",
    "human_gates",
    "surfaces",
    "blocked_actions",
    "promotion_rule"
  ],
  "properties": {
    "version": { "const": "eve-runtime-policy/v0" },
    "updated_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "profile": { "type": "string" },
    "release_band": { "type": "string" },
    "default_mode": { "const": "proposal_only" },
    "north_star": { "const": "founder-offline-test" },
    "policy_summary": { "type": "string" },
    "human_gates": {
      "type": "object",
      "required": [
        "durable_memory_write",
        "runtime_auth_or_model_default_change",
        "worker_dispatch",
        "public_publish_send_schedule_spend",
        "founder_offline_claim"
      ],
      "additionalProperties": { "type": "string" }
    },
    "surfaces": {
      "type": "object",
      "required": ["aionui", "hermes"],
      "properties": {
        "aionui": { "$ref": "#/$defs/surface" },
        "hermes": { "$ref": "#/$defs/surface" }
      },
      "additionalProperties": true
    },
    "blocked_actions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "promotion_rule": { "type": "string" }
  },
  "$defs": {
    "surface": {
      "type": "object",
      "required": ["mode", "allowed_actions", "disabled_features", "env"],
      "properties": {
        "mode": { "type": "string" },
        "allowed_actions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "disabled_features": {
          "type": "array",
          "items": { "$ref": "#/$defs/feature" }
        },
        "gated_features": {
          "type": "array",
          "items": { "$ref": "#/$defs/feature" }
        },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "feature": {
      "type": "object",
      "required": ["id", "name", "reason"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "reason": { "type": "string" },
        "human_gate": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
