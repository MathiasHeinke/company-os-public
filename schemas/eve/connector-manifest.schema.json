{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://company-os.local/schemas/eve/connector-manifest.schema.json",
  "title": "Command EVE Connector Manifest",
  "type": "object",
  "required": ["version", "updated_at", "policy", "connectors"],
  "properties": {
    "version": {
      "const": "eve-connector-manifest/v0"
    },
    "updated_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "policy": {
      "type": "object",
      "required": ["default_mode", "setup_order", "secret_rule", "write_rule"],
      "properties": {
        "default_mode": { "type": "string" },
        "setup_order": { "type": "string" },
        "secret_rule": { "type": "string" },
        "write_rule": { "type": "string" }
      },
      "additionalProperties": true
    },
    "connectors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "tier",
          "purpose",
          "required_for",
          "auth_method",
          "auth_surface",
          "setup_mode",
          "safe_preflight",
          "verify_command",
          "allowed_actions",
          "blocked_actions",
          "human_gate",
          "memory_policy"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "name": { "type": "string" },
          "tier": {
            "enum": ["core", "autonomy_core", "recommended", "gated", "optional_gated"]
          },
          "purpose": { "type": "string" },
          "required_for": {
            "type": "array",
            "items": { "type": "string" }
          },
          "auth_method": { "type": "string" },
          "auth_surface": { "type": "string" },
          "setup_mode": { "type": "string" },
          "safe_preflight": {
            "type": "array",
            "items": { "type": "string" }
          },
          "verify_command": { "type": "string" },
          "allowed_actions": {
            "type": "array",
            "items": { "type": "string" }
          },
          "blocked_actions": {
            "type": "array",
            "items": { "type": "string" }
          },
          "human_gate": { "type": "string" },
          "memory_policy": { "type": "string" },
          "preflight_result_file": {
            "type": "string",
            "description": "Path template for the local preflight result file written by the verify command. Relative to the client workspace root. When this file exists and ok===true, the connector state may be promoted to connected."
          }
        },
        "additionalProperties": true
      }
    },
    "ui_state_model": {
      "type": "object",
      "description": "Documents the two-layer state authority: manifest policy (tier/setup_mode) vs live preflight evidence files.",
      "properties": {
        "state_authority": { "type": "string" },
        "manifest_state_source": { "type": "string" },
        "evidence_state_source": { "type": "string" },
        "connected_requires": { "type": "string" },
        "gated_override_rule": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
