{
  "version": "capability-registry/example-v1",
  "generated_at": "2026-01-01",
  "profiles": [
    {
      "id": "claude-clevel-worker/cto/[client]",
      "name": "Claude CTO Worker Template",
      "role": "role:cto",
      "agents": ["claude"],
      "modes": ["audit", "plan", "implement", "verify", "review"],
      "workspaces": ["[client]", "registry:[client]", "[ABSOLUTE_WORKSPACE_PATH]"],
      "max_autonomy_level": "L2",
      "allowed_plugins": ["claude-code", "filesystem", "plane-app"],
      "allowed_connectors": ["filesystem", "plane-app"],
      "restricted_connectors": ["production-database", "payment-provider", "email-send"],
      "allowed_commands": ["node", "git", "rg", "pnpm", "npm"],
      "allowed_claude_tools": [
        "Read",
        "Edit",
        "Write",
        "MultiEdit",
        "Glob",
        "Grep",
        "LS",
        "TodoWrite",
        "Bash(git status*)",
        "Bash(git diff*)",
        "Bash(git diff --check*)",
        "Bash(node --test*)"
      ],
      "gate_execution": {
        "worker_must_run_declared_gates": true,
        "harness_denial_is_blocker": true,
        "controller_reruns_gates": "always-for-final-verdict",
        "allowed_gate_classes": ["unit-test", "build", "lint", "typecheck", "git-diff", "secret-scan"]
      },
      "allowed_subagents": [],
      "memory": {
        "honcho_read": "none",
        "honcho_write": "proposal-only"
      },
      "forbidden_surfaces": [
        "direct-memory-write",
        "plane-done-by-worker",
        "production-write",
        "public-publish"
      ],
      "sandbox_workspaces": ["[ABSOLUTE_SANDBOX_ROOT]/**"],
      "human_gates": ["HG-2", "HG-3"],
      "last_verified_at": "2026-01-01",
      "stale_after_days": 14
    }
  ]
}
