{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://company-os.local/schemas/domain-pack-registry.schema.json",
  "title": "Company.OS Domain Pack Registry",
  "type": "object",
  "required": ["version", "packs"],
  "additionalProperties": true,
  "properties": {
    "version": {
      "type": "string",
      "const": "domain-pack-registry/v0"
    },
    "generated_at": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "activation_policy": {
      "type": "object"
    },
    "packs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "owner_role",
          "first_useful_scope",
          "intake_questions",
          "ai_discovery",
          "outputs",
          "default_human_gate",
          "activation_mode",
          "operator_confirmation_required",
          "blocked_actions"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "owner_role": {
            "type": "string",
            "enum": ["role:cto", "role:cpo", "role:cmo", "role:coo", "role:cfo", "role:cao"]
          },
          "first_useful_scope": {
            "type": "string",
            "minLength": 1
          },
          "intake_questions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "ai_discovery": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "outputs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "default_human_gate": {
            "type": "string",
            "enum": ["HG-1", "HG-2", "HG-2.5", "HG-3", "HG-3.5", "HG-4"]
          },
          "activation_mode": {
            "type": "string",
            "minLength": 1
          },
          "operator_confirmation_required": {
            "type": "boolean"
          },
          "blocked_actions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
