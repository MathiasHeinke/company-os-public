# Company.OS Environment Variables — Example
#
# Copy this file to .env and fill in your values before running the kit.
# Never commit a filled-in .env to version control.
# All values here are placeholders only.

# ─── Plane App (execution ledger) ─────────────────────────────────────────────
# Preferred: use the Plane App OAuth bot-token flow (no long-lived personal key).
# See docs/integrations/plane-app-control-plane.md for setup.

PLANE_BASE_URL=https://api.plane.so
PLANE_WORKSPACE_SLUG=your-workspace-slug
PLANE_PROJECT_ID=your-project-id

# Authentication mode: "app-token" (preferred) or "api-key" (bootstrap fallback).
PLANE_AUTH_MODE=app-token

# Plane App OAuth credentials (set when auth mode is app-token).
PLANE_APP_CLIENT_ID=
PLANE_APP_CLIENT_SECRET=
PLANE_APP_TOKEN=

# Personal API key — bootstrap/fallback only; do not use in production scheduler.
PLANE_API_KEY=

# Optional: path to a JSON file mapping role labels to Plane label IDs.
PLANE_LABEL_MAP_PATH=

# ─── Honcho (memory layer) ────────────────────────────────────────────────────
# Use separate workspace IDs per memory class (company, personal, product).
# See docs/operations/client-productization-readiness.md#honcho-setup-boundary.

HONCHO_APP_ID=
HONCHO_USER_ID=
HONCHO_AUTH_HEADER=

# Workspace IDs — keep company, personal and product memory separate.
HONCHO_COMPANY_WORKSPACE_ID=
HONCHO_PERSONAL_WORKSPACE_ID=
HONCHO_PRODUCT_WORKSPACE_ID=

# ─── GitHub ───────────────────────────────────────────────────────────────────
# Fine-grained PAT with repo-scoped read (and write only when CI/CD requires it).
GITHUB_TOKEN=

# ─── Runtime / Scheduler ──────────────────────────────────────────────────────
# Absolute path to the installed Company.OS repo root on this machine.
COMPANY_OS_ROOT=${HOME}/Developer/Company.OS

# Set to "1" to halt all scheduled runtime dispatches immediately.
COMPANY_OS_RUNTIME_KILL_SWITCH=

# Inference registry path (leave blank to use the default inside COMPANY_OS_ROOT).
COMPANY_OS_INFERENCE_REGISTRY=

# Optional: polling interval for kill-switch checks (milliseconds, default 60000).
COMPANY_OS_RUNTIME_KILL_SWITCH_POLL_MS=

# Contract-review enforcement for the Plane Dispatcher.
# "require" (default) blocks dispatch until a CONTRACT_PASS comment exists.
COMPANY_OS_CONTRACT_REVIEW=require

# ─── AI Model Providers ───────────────────────────────────────────────────────
# Fill in only the providers you intend to use.  Rotate keys regularly.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─── Supabase (optional — only if the client product needs a database) ────────
# Supabase is NOT required for a pure Company.OS control-plane install.
# See docs/operations/client-productization-readiness.md#supabase-boundary.
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Service-role key must NEVER be committed or shared with workers.
# SUPABASE_SERVICE_ROLE_KEY=
